#ejercicio 25
cantidad_obreros = int(input("Ingrese la cantidad de obreros: "))

contador = 1

while contador <= cantidad_obreros:
    print("Obrero número:", contador)

    horas = float(input("Ingrese horas trabajadas: "))
    valor_hora = float(input("Ingrese valor por hora: "))

    if horas <= 40:
        sueldo = horas * valor_hora
    else:
        horas_extra = horas - 40

        if horas_extra <= 8:
            sueldo = (40 * valor_hora) + (horas_extra * valor_hora * 2)
        else:
            sueldo = (40 * valor_hora) + (8 * valor_hora * 2) + ((horas_extra - 8) * valor_hora * 3)

    print("El sueldo semanal es:", sueldo)

    contador = contador + 1

